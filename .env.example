# API base URL (Mordobo API) — usada para el resto de endpoints del Backoffice (onboarding, quejas, etc.)
VITE_API_BASE_URL=http://localhost:3000

# Opcional: si usas una API de login de admins aparte, pon su URL aquí. Si no, el login usa la misma VITE_API_BASE_URL con POST /auth/admin/login (proyecto Mordobo API).
# VITE_AUTH_ADMIN_URL=http://localhost:3100
VITE_AUTH_ADMIN_URL=

# Optional: required for admin-only endpoints (approve/reject provider)
# Get this from your API server ADMIN_SECRET
VITE_ADMIN_SECRET=

# Optional: en desarrollo, si el login es con este email y la API no devuelve role, se usa rol Super Admin
# Ejemplo: VITE_DEV_SUPER_ADMIN_EMAIL=superadmin@mordobo.com
VITE_DEV_SUPER_ADMIN_EMAIL=
